<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules: Prevent user data from being exported/transferred
   All user data (messages, chats, users) is excluded from backups and transfers
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude database files (messages, users, chats) -->
        <exclude domain="database" path="chat_app_db" />
        <exclude domain="database" path="chat_app_db-journal" />
        <exclude domain="database" path="chat_app_db-shm" />
        <exclude domain="database" path="chat_app_db-wal" />
        
        <!-- Exclude shared preferences containing user data -->
        <exclude domain="sharedpref" path="kafka_chat_prefs.xml" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Exclude database files from device-to-device transfers -->
        <exclude domain="database" path="chat_app_db" />
        <exclude domain="database" path="chat_app_db-journal" />
        <exclude domain="database" path="chat_app_db-shm" />
        <exclude domain="database" path="chat_app_db-wal" />
        
        <!-- Exclude shared preferences containing user data -->
        <exclude domain="sharedpref" path="kafka_chat_prefs.xml" />
    </device-transfer>
</data-extraction-rules>